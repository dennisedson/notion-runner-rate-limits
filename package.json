{
  "name": "notion-runner-rate-limits",
  "version": "0.1.0",
  "description": "A community reference of common API rate limits for Notion Workers.",
  "license": "MIT",
  "type": "module",
  "private": true,
  "author": "Dennis Edson",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dennisedson/notion-runner-rate-limits.git"
  },
  "bugs": {
    "url": "https://github.com/dennisedson/notion-runner-rate-limits/issues"
  },
  "homepage": "https://github.com/dennisedson/notion-runner-rate-limits#readme",
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "validate": "tsx scripts/validate-registry.ts",
    "build:json": "tsx scripts/build-json.ts",
    "check:json": "tsx scripts/build-json.ts --check",
    "lint": "eslint . && prettier --check .",
    "format": "prettier --write ."
  },
  "keywords": [
    "notion",
    "notion-workers",
    "rate-limit",
    "pacer",
    "api"
  ],
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.0.1",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.7.0",
    "prettier": "^3.3.0",
    "tsx": "^4.15.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.0.0",
    "vitest": "^4.1.9"
  }
}
